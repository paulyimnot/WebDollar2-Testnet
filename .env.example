# ============================================================
# WebDollar 2 - Node Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to Git.
# ============================================================

# ------------------------------------------------------------
# CORE (Required)
# ------------------------------------------------------------

# A long, random string for session encryption. Generate one at: https://generate-secret.vercel.app/64
SESSION_SECRET=

# Your PostgreSQL connection string.
# Docker users: leave this as-is, Docker handles it automatically.
# Manual users: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://webdollar2user:webdollar2password@postgres:5432/webdollar2db

# Port the node listens on
PORT=5000

# Set to "production" for live deployments
NODE_ENV=production

# ------------------------------------------------------------
# CLUSTER / NETWORK (Required to join the mainnet)
# ------------------------------------------------------------

# The shared secret that authenticates nodes in the cluster.
# Get this from the WebDollar 2 community. MUST match all other nodes.
CLUSTER_SECRET=

# Comma-separated list of existing node URLs to connect to.
# Example: https://node1.webdollar2.com,https://node2.webdollar2.com
CLUSTER_PEERS=

# ------------------------------------------------------------
# NODE REWARDS (Required to earn your share)
# ------------------------------------------------------------

# Your WEBD2 wallet address. This is where your backbone fees
# and daily node pool rewards will be sent.
# Must start with "WEBD" and be at least 20 characters long.
OPERATOR_WALLET_ADDRESS=
