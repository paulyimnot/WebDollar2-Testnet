{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "types": [
      "vite/client"
    ],
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./client/src/*"
      ],
      "@shared/*": [
        "./replit_frontend/webdollar_core/Webdollar-Core-Revive/shared/*"
      ],
      "@assets/*": [
        "./replit_frontend/webdollar_core/Webdollar-Core-Revive/attached_assets/*"
      ],
      "@blockchain/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "client/src"
  ]
}